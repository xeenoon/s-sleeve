<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= pageTitle %></title>
  <style>
    :root {
      --bg: #f4efe8;
      --panel: rgba(255, 250, 244, 0.94);
      --line: rgba(57, 39, 25, 0.12);
      --text: #251912;
      --muted: #6f5849;
      --accent: #b75527;
      --accent-soft: rgba(183, 85, 39, 0.12);
      --good: #2f7d53;
      --warn: #b2661f;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at top left, rgba(240, 194, 155, 0.85), transparent 26%),
        radial-gradient(circle at bottom right, rgba(183, 85, 39, 0.12), transparent 30%),
        linear-gradient(160deg, #faf5ef, var(--bg));
      color: var(--text);
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    }
    .server-shell {
      width: min(1120px, calc(100vw - 28px));
      margin: 18px auto;
      padding: 22px;
      border-radius: 28px;
      background: var(--panel);
      border: 1px solid var(--line);
      box-shadow: 0 24px 60px rgba(45, 29, 18, 0.12);
    }
    .masthead {
      display: grid;
      gap: 14px;
      grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
      align-items: end;
      margin-bottom: 20px;
      padding-bottom: 18px;
      border-bottom: 1px solid var(--line);
    }
    .eyebrow {
      margin: 0 0 10px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-size: 0.78rem;
      color: var(--muted);
    }
    h1 {
      margin: 0;
      font-size: clamp(2.2rem, 5vw, 4rem);
      line-height: 0.94;
      color: var(--accent);
    }
    .subtitle { margin: 12px 0 0; color: var(--muted); max-width: 58ch; }
    .server-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      justify-content: flex-end;
      align-content: start;
    }
    .server-nav a {
      text-decoration: none;
      color: var(--text);
      border: 1px solid var(--line);
      background: #fffaf4;
      padding: 10px 14px;
      border-radius: 999px;
    }
    .server-nav a:hover { border-color: rgba(183, 85, 39, 0.3); }
    .hero-badge, .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent);
      font-size: 0.9rem;
    }
    .grid-3, .grid-2, .stack { display: grid; gap: 16px; }
    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .panel, .list-card, .hero-card {
      border-radius: 22px;
      border: 1px solid var(--line);
      background: #fffaf4;
      padding: 18px;
    }
    .panel h2, .list-card h2, .hero-card h2 { margin: 0 0 10px; font-size: 1.15rem; }
    .stat-value { font-size: 2rem; font-weight: 700; color: var(--accent); margin-top: 8px; }
    .muted { color: var(--muted); }
    .notice.good { border-left: 4px solid var(--good); }
    .notice.warn { border-left: 4px solid var(--warn); }
    ul.clean {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 10px;
    }
    ul.clean li {
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255, 252, 248, 0.96);
      border: 1px solid rgba(57, 39, 25, 0.08);
    }
    .footer-note {
      margin-top: 18px;
      padding-top: 14px;
      border-top: 1px solid var(--line);
      color: var(--muted);
      font-size: 0.92rem;
    }
    @media (max-width: 860px) {
      .masthead, .grid-3, .grid-2 { grid-template-columns: 1fr; }
      .server-nav { justify-content: flex-start; }
    }
  </style>
</head>
<body>
  <div class="server-shell">
    <header class="masthead">
      <div>
        <p class="eyebrow"><%= eyebrow %></p>
        <h1><%= pageTitle %></h1>
        <p class="subtitle"><%= subtitle %></p>
      </div>
      <% include('partials/nav', nav) %>
    </header>
    <main>
      <%- body %>
    </main>
    <% include('partials/footer') %>
  </div>
</body>
</html>
