<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <style>
    :root {
      --bg: #f1ece4;
      --paper: rgba(255, 251, 246, 0.95);
      --line: rgba(64, 46, 33, 0.12);
      --text: #201711;
      --muted: #6b584c;
      --accent: #b45d32;
      --good: #2f7b55;
      --warn: #ba6a1f;
      --shadow: 0 24px 56px rgba(47, 30, 19, 0.12);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top right, rgba(180, 93, 50, 0.12), transparent 22%),
        linear-gradient(180deg, #faf4ed, var(--bg));
    }
    .page {
      width: min(1120px, calc(100vw - 28px));
      margin: 18px auto;
      padding: 22px;
      border-radius: 28px;
      background: var(--paper);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
    }
    .topbar, .grid, .footer-links { display: grid; gap: 16px; }
    .topbar {
      grid-template-columns: 1fr auto;
      align-items: center;
      border-bottom: 1px solid var(--line);
      padding-bottom: 14px;
    }
    .topbar a, .footer-links a {
      text-decoration: none;
      color: var(--text);
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,0.72);
      border: 1px solid var(--line);
      margin-left: 8px;
    }
    h1 { margin: 0; font-size: clamp(2.4rem, 6vw, 4.2rem); color: var(--accent); }
    .subtitle { margin: 12px 0 0; color: var(--muted); }
    .grid {
      grid-template-columns: 1.1fr 0.9fr;
      margin-top: 18px;
    }
    .panel {
      border-radius: 22px;
      border: 1px solid var(--line);
      background: #fffaf5;
      padding: 22px;
    }
    .kicker {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(47, 123, 85, 0.12);
      color: var(--good);
      font-size: 0.92rem;
    }
    .stack { display: grid; gap: 12px; margin-top: 16px; }
    .tile {
      padding: 14px;
      border-radius: 18px;
      background: rgba(255,255,255,0.82);
      border: 1px solid var(--line);
    }
    .tile strong { display: block; margin-bottom: 6px; }
    .callout {
      margin-top: 16px;
      padding: 14px;
      border-radius: 18px;
      background: rgba(180, 93, 50, 0.08);
      color: var(--muted);
    }
    .board {
      display: grid;
      gap: 12px;
    }
    .status-row {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
    .status-card {
      padding: 16px;
      border-radius: 18px;
      background: rgba(255,255,255,0.86);
      border: 1px solid var(--line);
    }
    .status-card span { color: var(--muted); display: block; }
    .status-card strong { font-size: 1.5rem; }
    @media (max-width: 860px) {
      .topbar, .grid, .status-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="topbar">
      <div>
        <h1><%= title %></h1>
        <p class="subtitle"><%= subtitle %></p>
      </div>
      <div>
        <a href="/server">Hub</a>
        <a href="/">Angular dashboard</a>
      </div>
    </section>

    <section class="grid">
      <article class="panel">
        <div class="kicker"><%= panelState %></div>
        <div class="stack">
          <div class="tile">
            <strong>Deployment wave</strong>
            Three clinics scheduled before the afternoon calibration block.
          </div>
          <div class="tile">
            <strong>Support roster</strong>
            One fitter on standby, two therapy reviewers active, one educator preparing onboarding.
          </div>
          <div class="tile">
            <strong>Consumables</strong>
            Sleeve liners, charging packs, and print packets all above the reorder threshold.
          </div>
        </div>
        <div class="callout"><%- calloutMarkup %></div>
      </article>

      <% if (showBoard) { %>
      <aside class="panel board">
        <div class="status-row">
          <div class="status-card">
            <span>Ready to fit</span>
            <strong>07</strong>
          </div>
          <div class="status-card">
            <span>Awaiting review</span>
            <strong>04</strong>
          </div>
          <div class="status-card">
            <span>Courier handoff</span>
            <strong>02</strong>
          </div>
          <div class="status-card">
            <span>Escalations</span>
            <strong style="color: var(--warn);">01</strong>
          </div>
        </div>
        <div class="tile">
          <strong>Why this page exists</strong>
          Operations teams often want a stable route that loads instantly and still feels branded without needing the full SPA boot path.
        </div>
      </aside>
      <% } %>
    </section>

    <div class="footer-links" style="margin-top: 18px;">
      <a href="/server/reports">Open reports</a>
      <a href="/server/variables">Open variables briefing</a>
    </div>
  </main>
</body>
</html>
