<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <style>
    :root {
      --bg: #f4eee7;
      --paper: rgba(255, 251, 246, 0.94);
      --line: rgba(62, 45, 33, 0.12);
      --text: #241b14;
      --muted: #6f5c50;
      --accent: #af5a31;
      --good: #317c56;
      --shadow: 0 24px 54px rgba(45, 28, 18, 0.12);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(255, 220, 189, 0.7), transparent 24%),
        linear-gradient(180deg, #faf4ee, var(--bg));
    }
    .page {
      width: min(1120px, calc(100vw - 28px));
      margin: 18px auto;
      padding: 22px;
      border-radius: 28px;
      background: var(--paper);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
    }
    .header, .report-grid, .digest-grid { display: grid; gap: 16px; }
    .header { grid-template-columns: 1fr auto; align-items: center; }
    .header a {
      text-decoration: none;
      color: var(--text);
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.74);
      margin-left: 8px;
    }
    h1 { margin: 0; font-size: clamp(2.3rem, 5.5vw, 4rem); color: var(--accent); }
    .subtitle { margin: 12px 0 0; color: var(--muted); }
    .report-grid { grid-template-columns: 1.15fr 0.85fr; margin-top: 18px; }
    .panel {
      border-radius: 22px;
      border: 1px solid var(--line);
      background: #fffaf5;
      padding: 22px;
    }
    .digest-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 14px;
    }
    .digest-card, .note {
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.84);
      padding: 16px;
    }
    .digest-card span { color: var(--muted); display: block; }
    .digest-card strong { display: block; margin-top: 8px; font-size: 1.7rem; }
    .note {
      color: var(--muted);
      line-height: 1.6;
      margin-top: 16px;
      background: rgba(49, 124, 86, 0.08);
    }
    .timeline {
      display: grid;
      gap: 12px;
    }
    .step {
      padding: 14px 16px;
      border-left: 4px solid var(--accent);
      background: rgba(255,255,255,0.86);
      border-radius: 0 16px 16px 0;
    }
    .step strong { display: block; margin-bottom: 6px; }
    .state {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(49, 124, 86, 0.12);
      color: var(--good);
      font-size: 0.92rem;
    }
    @media (max-width: 860px) {
      .header, .report-grid, .digest-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="header">
      <div>
        <h1><%= title %></h1>
        <p class="subtitle"><%= subtitle %></p>
      </div>
      <div>
        <a href="/server">Hub</a>
        <a href="/server/operations">Operations</a>
        <a href="/">Angular dashboard</a>
      </div>
    </section>

    <section class="report-grid">
      <article class="panel">
        <div class="state"><%= reportState %></div>
        <% if (showDigest) { %>
        <div class="digest-grid">
          <div class="digest-card">
            <span>Adherence score</span>
            <strong>94%</strong>
          </div>
          <div class="digest-card">
            <span>Sessions completed</span>
            <strong>128</strong>
          </div>
          <div class="digest-card">
            <span>Alerts closed</span>
            <strong>11</strong>
          </div>
        </div>
        <% } %>
        <div class="note"><%- insightMarkup %></div>
      </article>

      <aside class="panel timeline">
        <div class="step">
          <strong>07:10</strong>
          Overnight telemetry rolled into the review bundle and aligned with fit notes.
        </div>
        <div class="step">
          <strong>08:25</strong>
          Mobility specialists cleared the top priority outreach list for the morning round.
        </div>
        <div class="step">
          <strong>09:40</strong>
          Reporting page published for supervisors before the full SPA opened on clinic tablets.
        </div>
      </aside>
    </section>
  </main>
</body>
</html>
