<% layout('layouts/main') %>
<section class="stack">
  <div class="hero-card"><%- insightMarkup %></div>
  <div class="list-card">
    <h2>Available reports</h2>
    <ul class="clean">
      <% for (report of reportRows) { %>
        <li>
          <a href="/server/reports/<%= report.slug %>?audience=clinical lead"><%= report.title %></a>
          <div class="muted"><%= report.owner %></div>
        </li>
      <% } %>
    </ul>
  </div>
</section>
