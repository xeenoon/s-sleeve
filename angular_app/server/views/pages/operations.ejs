<% layout('layouts/main') %>
<section class="stack">
  <div class="hero-card"><%- summaryMarkup %></div>
  <div class="grid-3">
    <% for (column of columns) { %>
      <article class="list-card">
        <h2><%= column.heading %></h2>
        <ul class="clean">
          <% for (card of column.cards) { %>
            <li><%= card %></li>
          <% } %>
        </ul>
      </article>
    <% } %>
  </div>
</section>
