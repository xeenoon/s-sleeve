<% layout('layouts/main') %>
<section class="stack">
  <div class="hero-card">
    <%= heroMarkup %>
    <% if (audience) { %>
      <p class="subtitle">Prepared for <span class="chip"><%= audience %></span></p>
    <% } else { %>
      <p class="subtitle">Add <span class="chip">?audience=field team</span> to the URL to see query-driven rendering.</p>
    <% } %>
  </div>
  <% include('partials/stat-strip', { value: stats }) %>
  <div class="grid-2">
    <% for (notice of notices) { %>
      <article class="panel notice <%= notice.tone %>">
        <h2><%= notice.title %></h2>
        <p class="muted"><%= notice.detail %></p>
      </article>
    <% } %>
  </div>
  <div class="list-card">
    <h2>Quick links</h2>
    <ul class="clean">
      <% for (item of quickLinks) { %>
        <li><a href="<%= item.href %>"><%= item.label %></a></li>
      <% } %>
    </ul>
  </div>
</section>
