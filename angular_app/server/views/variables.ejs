<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title %></title>
  <style>
    :root {
      --bg: #f3eee7;
      --paper: rgba(255, 250, 245, 0.94);
      --line: rgba(64, 46, 33, 0.12);
      --text: #241a13;
      --muted: #6f5b4e;
      --accent: #b65d31;
      --shadow: 0 24px 56px rgba(46, 29, 18, 0.12);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at right top, rgba(182, 93, 49, 0.13), transparent 24%),
        linear-gradient(180deg, #faf5ef, var(--bg));
    }
    .page {
      width: min(1080px, calc(100vw - 28px));
      margin: 18px auto;
      padding: 22px;
      border-radius: 28px;
      background: var(--paper);
      border: 1px solid var(--line);
      box-shadow: var(--shadow);
    }
    .header, .grid, .checklist { display: grid; gap: 16px; }
    .header {
      grid-template-columns: 1fr auto;
      align-items: center;
      border-bottom: 1px solid var(--line);
      padding-bottom: 14px;
    }
    .header a {
      text-decoration: none;
      color: var(--text);
      padding: 10px 14px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.74);
      margin-left: 8px;
    }
    h1 { margin: 0; font-size: clamp(2.3rem, 5.5vw, 4rem); color: var(--accent); }
    .status {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(182, 93, 49, 0.1);
      color: var(--accent);
      font-size: 0.92rem;
    }
    .grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 18px;
    }
    .card {
      border-radius: 20px;
      border: 1px solid var(--line);
      background: #fffaf5;
      padding: 18px;
    }
    .card span { display: block; color: var(--muted); }
    .card strong { display: block; margin-top: 8px; font-size: 1.5rem; }
    .summary {
      margin-top: 16px;
      padding: 16px;
      border-radius: 18px;
      background: rgba(255,255,255,0.84);
      border: 1px solid var(--line);
      color: var(--muted);
      line-height: 1.6;
    }
    .inline-chip {
      display: inline-flex;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(47, 124, 86, 0.12);
      color: #2f7c56;
      border: 1px solid rgba(47, 124, 86, 0.16);
    }
    .checklist {
      margin-top: 18px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .item {
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,0.82);
      padding: 16px;
    }
    .item strong { display: block; margin-bottom: 8px; }
    @media (max-width: 860px) {
      .header, .grid, .checklist { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="header">
      <div>
        <h1><%= title %></h1>
        <p class="status"><%= status %></p>
      </div>
      <div>
        <a href="/server">Hub</a>
        <a href="/">Angular dashboard</a>
      </div>
    </section>

    <section class="grid">
      <article class="card">
        <span>Goal threshold</span>
        <strong>85%</strong>
      </article>
      <article class="card">
        <span>Sync cadence</span>
        <strong>8s</strong>
      </article>
      <article class="card">
        <span>Write endpoint</span>
        <strong>/api/variables</strong>
      </article>
    </section>

    <div class="summary">
      <%- hintMarkup %>
      <p><%= summary %></p>
    </div>

    <% if (showChecklist) { %>
    <section class="checklist">
      <article class="item">
        <strong>Before a fitting session</strong>
        Confirm the patient target range, brace alignment, and previous session notes.
      </article>
      <article class="item">
        <strong>During live tuning</strong>
        Hand off to the Angular dashboard for real-time values, motion response, and save actions.
      </article>
    </section>
    <% } %>
  </main>
</body>
</html>
